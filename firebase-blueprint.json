{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "role"]
    },
    "Doctor": {
      "title": "Doctor Information",
      "description": "Detailed professional information for doctors.",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "specialty": { "type": "string" },
        "qualifications": { "type": "array" },
        "bio": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "price": { "type": "number" },
        "availability": { "type": "object" }
      },
      "required": ["doctorId", "specialty"]
    },
    "Appointment": {
      "title": "Medical Appointment",
      "description": "An appointment booking between a patient and a doctor.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "notes": { "type": "string" },
        "meetLink": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "status"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A communication channel between a patient and a doctor.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "An individual message within a chat.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records."
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor metadata records."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment bookings."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat session documents."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages within a chat."
    }
  }
}
